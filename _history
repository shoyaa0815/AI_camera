el.G, GigoMotor.MotorShaftDirection.LOW, 100)\n    basic.pause(500)\n    while (true) {\n        GigoMotor.motorControl2(GigoMotor.MotorChannel.G, GigoMotor.MotorShaftDirection.LOW, 50)\n        GigoMotor.motorControl2(GigoMotor.MotorChannel.F, GigoMotor.MotorShaftDirection.LOW, 50)\n        // ใช้ if แทน while เพื่อให้ break ออกนอกลูปหลักได้\n        if (GigoSensor.isblack(GigoSensor.BlackChannel.P16) && GigoSensor.notblack(GigoSensor.BlackChannel.P1)) {\n            GigoMotor.motorStop1(GigoMotor.MotorChannel.F)\n            GigoMotor.motorStop1(GigoMotor.MotorChannel.G)\n            // ออกจาก while(true)\n            break;\n        }\n    }\n}\nfunction FFlinewithpid () {\n    Kp = 50\n    baseSpeed = 100\n    while (true) {\n        // sensor ซ้าย\n        L = pins.digitalReadPin(DigitalPin.P1)\n        // sensor ขวา\n        R = pins.digitalReadPin(DigitalPin.P16)\n        // หยุดเมื่อเจอเส้นทั้ง 2 ข้าง\n        if (L == 1 && R == 1) {\n            GigoMotor.motorStop1(GigoMotor.MotorChannel.F)\n            GigoMotor.motorStop1(GigoMotor.MotorChannel.G)\n            break;\n        }\n        // คำนวณ error\n        if (L == 0 && R == 1) {\n            // เลี้ยวซ้าย\n            error = -1\n        } else if (L == 1 && R == 0) {\n            // เลี้ยวขวา\n            error = 1\n        } else {\n            // ตรงกลาง\n            error = 0\n        }\n        correction = error * Kp\n        leftSpeed = baseSpeed - correction\n        rightSpeed = baseSpeed + correction\n        // จำกัดความเร็วไม่ให้เกิน 0–255\n        leftSpeed = Math.min(Math.max(leftSpeed, 0), 255)\n        rightSpeed = Math.min(Math.max(rightSpeed, 0), 255)\n        // ส่งคำสั่งควบคุมมอเตอร์\n        GigoMotor.motorControl2(GigoMotor.MotorChannel.G, GigoMotor.MotorShaftDirection.LOW, leftSpeed)\n        GigoMotor.motorControl2(GigoMotor.MotorChannel.F, GigoMotor.MotorShaftDirection.HIGH, rightSpeed)\n        // หน่วงเวลานิดหน่อยเพื่อให้ทำงานลื่น\n        basic.pause(10)\n    }\n}\nfuncti