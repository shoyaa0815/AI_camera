gitalPin.P1) < 1) {\n            GigoMotor.motorControl2(GigoMotor.MotorChannel.G, GigoMotor.MotorShaftDirection.LOW, 80)\n            GigoMotor.motorStop1(GigoMotor.MotorChannel.F)\n        } else if (pins.digitalReadPin(DigitalPin.P16) < 1) {\n            GigoMotor.motorControl2(GigoMotor.MotorChannel.F, GigoMotor.MotorShaftDirection.HIGH, 80)\n            GigoMotor.motorStop1(GigoMotor.MotorChannel.G)\n        } else if (GigoSensor.isblack(GigoSensor.BlackChannel.P1) && GigoSensor.isblack(GigoSensor.BlackChannel.P16)) {\n            GigoMotor.motorControl2(GigoMotor.MotorChannel.G, GigoMotor.MotorShaftDirection.LOW, 70)\n            GigoMotor.motorControl2(GigoMotor.MotorChannel.F, GigoMotor.MotorShaftDirection.HIGH, 70)\n            basic.pause(50)\n            GigoMotor.motorStop1(GigoMotor.MotorChannel.G)\n            GigoMotor.motorStop1(GigoMotor.MotorChannel.F)\n            break;\n        } else {\n            GigoMotor.motorControl2(GigoMotor.MotorChannel.G, GigoMotor.MotorShaftDirection.LOW, 100)\n            GigoMotor.motorControl2(GigoMotor.MotorChannel.F, GigoMotor.MotorShaftDirection.HIGH, 100)\n        }\n    }\n}\nlet rightSpeed = 0\nlet leftSpeed = 0\nlet correction = 0\nlet error = 0\nlet R = 0\nlet L = 0\nlet baseSpeed = 0\nlet Kp = 0\nlet bt = 0\npins.setPull(DigitalPin.P8, PinPullMode.PullUp)\nwhile (true) {\n    if (input.buttonIsPressed(Button.B)) {\n        bt += 1\n        basic.showNumber(bt)\n        if (bt > 3) {\n            bt = 0\n        }\n    }\n    if (bt == 1) {\n        if (pins.digitalReadPin(DigitalPin.P8) == 0) {\n            ไปซ้ายของแทร่()\n        }\n    }\n    if (bt == 2 && pins.digitalReadPin(DigitalPin.P8) == 0) {\n        ไปกลางของแทร่()\n    }\n    if (bt == 3 && pins.digitalReadPin(DigitalPin.P8) == 0) {\n        ไปขวาของแทร่()\n    }\n}\n"]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":2,"length1":29,"diffs":[[1,"    \"name\": \"cctv\",\n"]]},{"start1":193,"length1":152,"diffs":[[1,"        \"senso